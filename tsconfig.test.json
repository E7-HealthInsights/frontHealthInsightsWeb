{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types":                ["jest", "@testing-library/jest-dom", "node"],
    "noUnusedLocals":       false,
    "noUnusedParameters":   false,
    "verbatimModuleSyntax": false,
    "moduleResolution":     "node",
    "esModuleInterop":      true,
    "module":               "CommonJS"
  },
  "include": ["src"]
}